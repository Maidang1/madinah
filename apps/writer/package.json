{
  "name": "writer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "out/main/index.cjs",
  "scripts": {
    "dev": "electron-rsbuild dev",
    "build": "tsc --noEmit && electron-rsbuild build",
    "preview": "electron-rsbuild preview",
    "electron:build": "pnpm build && CSC_IDENTITY_AUTO_DISCOVERY=false npm_config_user_agent=npm npm_execpath=npm electron-builder --mac --universal --publish never",
    "electron:publish": "pnpm build && npm_config_user_agent=npm npm_execpath=npm electron-builder --mac --universal --publish always",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.1.0",
    "@aws-sdk/client-s3": "^3.1076.0",
    "@mdx-js/mdx": "^3.1.1",
    "@mdxeditor/editor": "^4.0.4",
    "@shikijs/langs": "^4.3.0",
    "@shikijs/rehype": "^4.3.0",
    "@shikijs/themes": "^4.3.0",
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.21.0",
    "motion": "^12.42.0",
    "react": "^19.2.7",
    "react-arborist": "^3.10.5",
    "react-dom": "^19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
