    "@rsbuild/plugin-react": "^1.4.6",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/shell-quote": "^1.7.5",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
