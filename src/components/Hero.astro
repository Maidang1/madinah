---
// Hero component for homepage
---

<div class="relative overflow-hidden">
  <!-- Background geometric decoration -->
  <div class="pointer-events-none absolute -right-20 top-0 h-[500px] w-[500px]">
    <div class="absolute right-0 top-0 h-64 w-64 rounded-full bg-gradient-to-br from-text-primary/[0.04] to-transparent blur-3xl animate-pulse"></div>
    <div class="absolute right-20 top-20 h-48 w-48 rounded-full bg-gradient-to-br from-text-primary/[0.02] to-transparent blur-2xl animate-pulse" style="animation-delay: 1000ms"></div>
  </div>

  <div class="relative">
    <!-- Label -->
    <div class="mb-6 flex items-center gap-3">
      <span class="inline-flex items-center gap-1.5 text-xs font-medium uppercase tracking-widest text-text-muted">
        <span class="h-1.5 w-1.5 rounded-full bg-text-primary animate-pulse"></span>
        Available for projects
      </span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr,auto] gap-12 items-start">
      <div class="space-y-6">
        <!-- Main headline -->
        <h1 class="text-text-primary font-sans text-5xl font-bold tracking-tight sm:text-6xl lg:text-7xl leading-[1.05]">
          你好，我是
          <span class="relative inline-block">
            Madinah
            <span class="absolute -bottom-2 left-0 h-1 w-full bg-gradient-to-r from-text-primary via-text-secondary to-transparent"></span>
          </span>
        </h1>

        <!-- Description -->
        <p class="text-text-secondary max-w-xl text-xl leading-relaxed sm:text-2xl" style="letter-spacing: -0.01em;">
          前端开发者，目前在学习 Rust。
          <span class="text-text-muted">热爱构建优雅、高效的工具与应用。</span>
        </p>

        <!-- Social links with enhanced styling -->
        <div class="flex items-center gap-8 pt-4">
          <a
            href="https://github.com/Maidang1"
            target="_blank"
            rel="noopener noreferrer"
            class="group relative text-text-muted transition-all duration-300 hover:text-text-primary"
            aria-label="GitHub"
          >
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" stroke="none">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
            <span class="absolute -bottom-1 left-0 h-px w-0 bg-text-primary transition-all duration-300 group-hover:w-full"></span>
          </a>
          <a
            href="https://twitter.com"
            target="_blank"
            rel="noopener noreferrer"
            class="group relative text-text-muted transition-all duration-300 hover:text-text-primary"
            aria-label="Twitter"
          >
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" stroke="none">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
            <span class="absolute -bottom-1 left-0 h-px w-0 bg-text-primary transition-all duration-300 group-hover:w-full"></span>
          </a>
          <a
            href="/rss.xml"
            target="_blank"
            rel="noopener noreferrer"
            class="group relative text-text-muted transition-all duration-300 hover:text-text-primary"
            aria-label="RSS"
          >
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" stroke="none">
              <path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795.001 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.71-7.118-15.758-15.839-15.82zm0-3.368c10.58.046 19.152 8.594 19.183 19.188h4.817c-.03-13.231-10.755-23.954-24-24v4.812z"/>
            </svg>
            <span class="absolute -bottom-1 left-0 h-px w-0 bg-text-primary transition-all duration-300 group-hover:w-full"></span>
          </a>
        </div>
      </div>

      <!-- Decorative side element -->
      <div class="hidden lg:flex flex-col items-center gap-4 pt-8">
        <div class="h-20 w-px bg-gradient-to-b from-transparent via-text-muted/30 to-transparent"></div>
        <span class="text-xs text-text-muted tracking-widest rotate-90 origin-center translate-y-8" style="writing-mode: vertical-rl;">FRONTEND ENGINEER</span>
      </div>
    </div>
  </div>
</div>
