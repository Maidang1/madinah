---
import type { HTMLAttributes } from 'astro/types';
import { cn } from '../../utils/cn';

interface Props extends HTMLAttributes<'table'> {}

const { class: className, ...props } = Astro.props;
---

<div class="table-wrapper">
  <table
    class={cn(
      className
    )}
    {...props}
  >
    <slot />
  </table>
</div>
