---
import type { HTMLAttributes } from 'astro/types';
import { cn } from '../../utils/cn';

interface Props {
  type?: 'info' | 'warning' | 'error' | 'success' | 'note';
  title?: string;
  class?: string;
}

const { type = 'info', title, class: className } = Astro.props;

const typeStyles = {
  info: 'border-border-default bg-surface-gray-100 text-text-primary',
  warning: 'border-border-default bg-surface-gray-100 text-text-primary',
  error: 'border-border-default bg-surface-gray-100 text-text-primary',
  success: 'border-border-default bg-surface-gray-100 text-text-primary',
  note: 'border-border-default bg-surface-gray-100 text-text-primary',
};
---

<div class={cn('my-6 rounded-lg border p-4', typeStyles[type], className)}>
  {title && (
    <div class="mb-2 font-semibold">{title}</div>
  )}
  <div>
    <slot />
  </div>
</div>
