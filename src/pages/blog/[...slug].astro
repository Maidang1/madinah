---
import { getCollection, render } from "astro:content";
import { components } from "../../components/mdx";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LicenseNotice from "../../components/LicenseNotice.astro";
import Time from "../../components/Time.astro";
import { calculateReadingTime } from "../../utils/reading-time";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const readingTime = calculateReadingTime(post.body);
const tocItems = Array.from(post.body.matchAll(/^(#{1,3})\s+(.+)$/gm))
    .map((match) => {
        const depth = match[1].length;
        const text = match[2]
            .replace(/`([^`]+)`/g, "$1")
            .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
            .replace(/[*_#]/g, "")
            .trim();
        const id = text
            .toLowerCase()
            .replace(/[^\p{Letter}\p{Number}\s-]/gu, "")
            .trim()
            .replace(/\s+/g, "-");

        return { depth, text, id };
    })
    .filter((item) => item.text && item.id)
    .slice(0, 12);
---

<BaseLayout title={`${post.data.title} - Madinah's Blog`} description={post.data.description}>
  <article>
    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>

      <div class="post-meta">
        <span>Date:</span>
        <Time time={post.data.pubDate} />
        <span>|</span>
        <span>Estimated Reading Time: {readingTime.minutes} min</span>
        {post.data.author && (
          <>
            <span>|</span>
            <span>Author: {post.data.author}</span>
          </>
        )}
      </div>
    </header>

    {tocItems.length > 0 && (
      <div class="toc">
        <details>
          <summary accesskey="c" title="(Alt + C)">
            <span class="details">Table of Contents</span>
          </summary>

          <div class="inner">
            <ul>
              {tocItems.map((item) => (
                <li class:list={[item.depth > 1 && "toc-depth-3"]}>
                  <a href={`#${item.id}`} aria-label={item.text}>{item.text}</a>
                </li>
              ))}
            </ul>
          </div>
        </details>
      </div>
    )}

    <div class="post-content">
      <Content components={components} />
    </div>

    <LicenseNotice />
  </article>
</BaseLayout>
