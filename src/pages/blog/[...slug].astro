---
import { render } from "astro:content";
import { components } from "../../components/mdx";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LicenseNotice from "../../components/LicenseNotice.astro";
import Time from "../../components/Time.astro";
import { calculateReadingTime } from "../../utils/reading-time";
import { getPostBody, getPublishedPosts } from "../../utils/posts";

export async function getStaticPaths() {
    const posts = await getPublishedPosts();
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const postBody = getPostBody(post);
const readingTime = calculateReadingTime(postBody);
const tocItems = Array.from(postBody.matchAll(/^(#{1,3})\s+(.+)$/gm))
    .map((match) => {
        const depth = match[1].length;
        const text = match[2]
            .replace(/`([^`]+)`/g, "$1")
            .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
            .replace(/[*_#]/g, "")
            .trim();
        const id = text
            .toLowerCase()
            .replace(/[^\p{Letter}\p{Number}\s-]/gu, "")
            .trim()
            .replace(/\s+/g, "-");

        return { depth, text, id };
    })
    .filter((item) => item.text && item.id)
    .slice(0, 12);
---

<BaseLayout title={`${post.data.title} - Madinah's Blog`} description={post.data.description}>
  <article class="post-shell">
    <div class="post-layout">
      <div class="post-main-column">
        <a href="/" class="post-back" aria-label="Back to blog list">
          <span aria-hidden="true">&larr;</span>
          Blog
        </a>

        <header class="post-header">
          <h1 class="post-title">{post.data.title}</h1>

          <div class="post-meta">
            <Time time={post.data.pubDate} />
            <span>/</span>
            <span>{readingTime.minutes} 分钟</span>
            {post.data.author && (
              <>
                <span>/</span>
                <span>{post.data.author}</span>
              </>
            )}
          </div>
        </header>

        {tocItems.length > 0 && (
          <div class="toc toc-mobile">
            <details>
              <summary accesskey="c" title="(Alt + C)">
                <span class="details">目录</span>
              </summary>

              <div class="inner">
                <ul>
                  {tocItems.map((item) => (
                    <li class:list={[item.depth > 2 && "toc-depth-3"]}>
                      <a href={`#${item.id}`} aria-label={item.text}>{item.text}</a>
                    </li>
                  ))}
                </ul>
              </div>
            </details>
          </div>
        )}

        <div class="post-content">
          <Content components={components} />
        </div>

        <LicenseNotice />
      </div>

      {tocItems.length > 0 && (
        <aside class="toc-rail" aria-label="目录">
          <h2>目录</h2>
          <nav>
            <ul>
              {tocItems.map((item, index) => (
                <li class:list={[item.depth > 2 && "toc-depth-3"]}>
                  <a
                    href={`#${item.id}`}
                    aria-label={item.text}
                    class:list={[index === 0 && "is-active"]}
                  >
                    {item.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}
    </div>
  </article>
</BaseLayout>
