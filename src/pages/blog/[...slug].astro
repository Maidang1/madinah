---
import { render } from "astro:content";
import { components } from "../../components/mdx";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LicenseNotice from "../../components/LicenseNotice.astro";
import Time from "../../components/Time.astro";
import { calculateReadingTime } from "@madinah/content-core";
import { getPostBody, getPublishedPosts } from "../../utils/posts";

export async function getStaticPaths() {
    const posts = await getPublishedPosts();
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const postBody = getPostBody(post);
const readingTime = calculateReadingTime(postBody);
const tocItems = headings
    .filter((heading) => heading.depth >= 1 && heading.depth <= 3)
    .map((heading) => ({
        depth: heading.depth,
        text: heading.text,
        id: heading.slug,
    }))
    .filter((item) => item.text && item.id);
---

<BaseLayout title={`${post.data.title} - Madinah's Blog`} description={post.data.description}>
  <article class="post-shell">
    <div class="post-layout">
      <div class="post-main-column">
        <a href="/" class="post-back" aria-label="Back to blog list">
          <span aria-hidden="true">&larr;</span>
          Blog
        </a>

        <header class="post-header">
          <h1 class="post-title">{post.data.title}</h1>

          <div class="post-meta-row">
            <div class="post-meta">
              <Time time={post.data.pubDate} />
              <span>/</span>
              <span>{readingTime.minutes} 分钟</span>
              {post.data.author && (
                <>
                  <span>/</span>
                  <span>{post.data.author}</span>
                </>
              )}
            </div>
            <div class="post-share">
              <button type="button" data-share-article aria-label="分享文章" title="分享文章">
                <svg aria-hidden="true" viewBox="0 0 24 24" width="15" height="15">
                  <path d="M8.7 12.9 15.4 17M15.4 7 8.7 11.1M19 20a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM6 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm13-5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
                </svg>
                <span>分享</span>
              </button>
              <span data-share-feedback aria-live="polite"></span>
            </div>
          </div>
        </header>

        {tocItems.length > 0 && (
          <div class="toc toc-mobile">
            <details>
              <summary accesskey="c" title="(Alt + C)">
                <span class="details">目录</span>
              </summary>

              <div class="inner">
                <ul>
                  {tocItems.map((item) => (
                    <li class:list={[item.depth > 2 && "toc-depth-3"]}>
                      <a href={`#${item.id}`} aria-label={item.text}>{item.text}</a>
                    </li>
                  ))}
                </ul>
              </div>
            </details>
          </div>
        )}

        <div class="post-content hw-scope">
          <Content components={components} />
        </div>

        <LicenseNotice />
      </div>

      {tocItems.length > 0 && (
        <aside class="toc-rail" aria-label="目录">
          <h2>目录</h2>
          <nav>
            <ul>
              {tocItems.map((item) => (
                <li class:list={[item.depth > 2 && "toc-depth-3"]}>
                  <a
                    href={`#${item.id}`}
                    aria-label={item.text}
                  >
                    {item.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}
    </div>
  </article>

  <script>
    function initArticleShare() {
      const button = document.querySelector<HTMLButtonElement>("[data-share-article]");
      const feedback = document.querySelector<HTMLElement>("[data-share-feedback]");
      if (!button || !feedback || button.dataset.bound === "true") return;
      button.dataset.bound = "true";

      const copyCurrentUrl = async () => {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(window.location.href);
          return;
        }
        const input = document.createElement("textarea");
        input.value = window.location.href;
        input.style.position = "fixed";
        input.style.opacity = "0";
        document.body.append(input);
        input.select();
        document.execCommand("copy");
        input.remove();
      };

      button.addEventListener("click", async () => {
        try {
          if (navigator.share) {
            await navigator.share({
              title: document.title,
              url: window.location.href,
            });
            feedback.textContent = "已分享";
          } else {
            await copyCurrentUrl();
            feedback.textContent = "链接已复制";
          }
          window.setTimeout(() => {
            feedback.textContent = "";
          }, 2200);
        } catch (error) {
          if (error instanceof DOMException && error.name === "AbortError") return;
          feedback.textContent = "分享失败";
        }
      });
    }

    function initToc() {
      const rail = document.querySelector<HTMLElement>(".toc-rail");
      if (!rail) return;

      const links = Array.from(
        rail.querySelectorAll<HTMLAnchorElement>("nav a[href^='#']")
      );
      if (links.length === 0) return;

      const linkById = new Map<string, HTMLAnchorElement>();
      const targets: HTMLElement[] = [];
      for (const link of links) {
        const id = decodeURIComponent(link.hash.slice(1));
        const target = id ? document.getElementById(id) : null;
        if (target) {
          linkById.set(id, link);
          targets.push(target);
        }
      }
      if (targets.length === 0) return;

      let activeId: string | null = null;

      const setActive = (id: string) => {
        if (id === activeId) return;
        activeId = id;
        for (const link of links) link.classList.remove("is-active");
        const active = linkById.get(id);
        if (!active) return;
        active.classList.add("is-active");

        // Keep the active link visible inside the (possibly scrolling) rail.
        const linkRect = active.getBoundingClientRect();
        const railRect = rail.getBoundingClientRect();
        if (linkRect.top < railRect.top || linkRect.bottom > railRect.bottom) {
          active.scrollIntoView({ block: "nearest", behavior: "smooth" });
        }
      };

      const visible = new Set<string>();
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            const id = entry.target.id;
            if (entry.isIntersecting) visible.add(id);
            else visible.delete(id);
          }
          // Pick the first heading in document order that is currently visible.
          const current = targets.find((t) => visible.has(t.id));
          if (current) {
            setActive(current.id);
          }
        },
        { rootMargin: "0px 0px -70% 0px", threshold: 0 }
      );

      for (const target of targets) observer.observe(target);

      // Initialise: activate the heading closest to the top of the viewport.
      const initial =
        targets.find((t) => t.getBoundingClientRect().top >= 0) ?? targets[0];
      setActive(initial.id);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", () => {
        initArticleShare();
        initToc();
      }, { once: true });
    } else {
      initArticleShare();
      initToc();
    }
    // Astro view transitions: re-init after swaps.
    document.addEventListener("astro:page-load", () => {
      initArticleShare();
      initToc();
    });
  </script>
</BaseLayout>
