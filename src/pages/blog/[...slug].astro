---
import { render } from "astro:content";
import { components } from "../../components/mdx";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LicenseNotice from "../../components/LicenseNotice.astro";
import Time from "../../components/Time.astro";
import { calculateReadingTime } from "@madinah/content-core";
import { getPostBody, getPublishedPosts } from "../../utils/posts";

export async function getStaticPaths() {
    const posts = await getPublishedPosts();
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const postBody = getPostBody(post);
const readingTime = calculateReadingTime(postBody);
const tocItems = headings
    .filter((heading) => heading.depth >= 1 && heading.depth <= 3)
    .map((heading) => ({
        depth: heading.depth,
        text: heading.text,
        id: heading.slug,
    }))
    .filter((item) => item.text && item.id);
---

<BaseLayout title={`${post.data.title} - Madinah's Blog`} description={post.data.description}>
  <article class="post-shell">
    <div class="post-layout">
      <div class="post-main-column">
        <a href="/" class="post-back" aria-label="Back to blog list">
          <span aria-hidden="true">&larr;</span>
          Blog
        </a>

        <header class="post-header">
          <h1 class="post-title">{post.data.title}</h1>

          <div class="post-meta">
            <Time time={post.data.pubDate} />
            <span>/</span>
            <span>{readingTime.minutes} 分钟</span>
            {post.data.author && (
              <>
                <span>/</span>
                <span>{post.data.author}</span>
              </>
            )}
          </div>
        </header>

        {tocItems.length > 0 && (
          <div class="toc toc-mobile">
            <details>
              <summary accesskey="c" title="(Alt + C)">
                <span class="details">目录</span>
              </summary>

              <div class="inner">
                <ul>
                  {tocItems.map((item) => (
                    <li class:list={[item.depth > 2 && "toc-depth-3"]}>
                      <a href={`#${item.id}`} aria-label={item.text}>{item.text}</a>
                    </li>
                  ))}
                </ul>
              </div>
            </details>
          </div>
        )}

        <div class="post-content">
          <Content components={components} />
        </div>

        <LicenseNotice />
      </div>

      {tocItems.length > 0 && (
        <aside class="toc-rail" aria-label="目录">
          <h2>目录</h2>
          <nav>
            <ul>
              {tocItems.map((item) => (
                <li class:list={[item.depth > 2 && "toc-depth-3"]}>
                  <a
                    href={`#${item.id}`}
                    aria-label={item.text}
                  >
                    {item.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}
    </div>
  </article>

  <script>
    function initToc() {
      const rail = document.querySelector<HTMLElement>(".toc-rail");
      if (!rail) return;

      const links = Array.from(
        rail.querySelectorAll<HTMLAnchorElement>("nav a[href^='#']")
      );
      if (links.length === 0) return;

      const linkById = new Map<string, HTMLAnchorElement>();
      const targets: HTMLElement[] = [];
      for (const link of links) {
        const id = decodeURIComponent(link.hash.slice(1));
        const target = id ? document.getElementById(id) : null;
        if (target) {
          linkById.set(id, link);
          targets.push(target);
        }
      }
      if (targets.length === 0) return;

      let activeId: string | null = null;

      const setActive = (id: string) => {
        if (id === activeId) return;
        activeId = id;
        for (const link of links) link.classList.remove("is-active");
        const active = linkById.get(id);
        if (!active) return;
        active.classList.add("is-active");

        // Keep the active link visible inside the (possibly scrolling) rail.
        const linkRect = active.getBoundingClientRect();
        const railRect = rail.getBoundingClientRect();
        if (linkRect.top < railRect.top || linkRect.bottom > railRect.bottom) {
          active.scrollIntoView({ block: "nearest", behavior: "smooth" });
        }
      };

      const visible = new Set<string>();
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            const id = entry.target.id;
            if (entry.isIntersecting) visible.add(id);
            else visible.delete(id);
          }
          // Pick the first heading in document order that is currently visible.
          const current = targets.find((t) => visible.has(t.id));
          if (current) {
            setActive(current.id);
          }
        },
        { rootMargin: "0px 0px -70% 0px", threshold: 0 }
      );

      for (const target of targets) observer.observe(target);

      // Initialise: activate the heading closest to the top of the viewport.
      const initial =
        targets.find((t) => t.getBoundingClientRect().top >= 0) ?? targets[0];
      setActive(initial.id);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initToc, { once: true });
    } else {
      initToc();
    }
    // Astro view transitions: re-init after swaps.
    document.addEventListener("astro:page-load", initToc);
  </script>
</BaseLayout>
