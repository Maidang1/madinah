---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Time from '../../components/Time.astro';
import { getPublishedPosts } from '../../utils/posts';

const postsWithReadingTime = await getPublishedPosts();
---

<BaseLayout title="Blog - Madinah">
  <div class="space-y-8">
    <h1 class="text-text-primary text-4xl font-bold tracking-tight sm:text-5xl">
      Blog
    </h1>

    <div class="grid grid-cols-1 gap-6">
      {postsWithReadingTime.map(post => (
        <a
          href={`/blog/${post.id}`}
          class="group block rounded-xl p-0 transition-all duration-200"
        >
          <article class="space-y-3">
            <h2 class="text-text-primary font-sans text-xl font-bold tracking-tight transition-colors group-hover:text-text-secondary">
              {post.data.title}
            </h2>

            {post.data.description && (
              <p class="text-text-secondary line-clamp-2 text-sm leading-relaxed transition-colors group-hover:text-text-muted">
                {post.data.description}
              </p>
            )}

            <div class="text-text-muted flex items-center gap-3 text-xs font-medium transition-colors group-hover:text-text-secondary">
              <Time time={post.data.pubDate} />
              <span>·</span>
              <span>{post.readingTime.minutes} min read</span>
              {post.data.author && (
                <>
                  <span>·</span>
                  <span>{post.data.author}</span>
                </>
              )}
            </div>
          </article>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
