---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    id: "wallpaper-app",
    name: "Wallpaper App",
    description: "A beautiful wallpaper application with curated collections",
    github: "https://github.com/Maidang1/wallpaper-app",
    category: "Application",
  },
  {
    id: "farmfe-plugins",
    name: "FarmFe Plugins",
    description: "Plugin ecosystem for Farm build tool",
    github: "https://github.com/farm-fe/plugins",
    category: "Tool",
  },
  {
    id: "pixel-picture",
    name: "Pixel Picture",
    description: "Pixel art editor and gallery",
    github: "https://github.com/Maidang1/pixel-picture",
    url: "https://pixel.felixwliu.cn/",
    category: "Creative",
  },
  {
    id: "reminders",
    name: "Reminders",
    description: "Simple and elegant reminder application",
    github: "https://github.com/Maidang1/reminders",
    category: "Application",
  },
  {
    id: "tasuku-rs",
    name: "tasuku-rs",
    description: "Rust implementation of tasuku task runner",
    github: "https://github.com/Maidang1/tasuku-rs",
    category: "Library",
  },
  {
    id: "reminder-cli",
    name: "Reminder CLI",
    description: "Command-line reminder tool",
    github: "https://github.com/Maidang1/reminder-cli",
    category: "Tool",
  },
  {
    id: "open-claude-cowork",
    name: "open-claude-cowork",
    description: "Use Agent Client Protocol Rebuild Cowork",
    github: "https://github.com/Maidang1/open-claude-cowork",
    category: "Framework",
  },
];
---

<BaseLayout
  title="Projects - Madinah"
  description="Projects that I created or maintain."
  variant="list"
>
  <section class="page-intro">
    <h1>Projects</h1>
    <p>A focused collection of tools, applications, and experiments I have built or maintained.</p>
  </section>

  <section aria-label="Projects">
    {
      projects.map((project) => (
        <a
          href={project.url ?? project.github}
          target="_blank"
          rel="noopener noreferrer"
          class="entry-card"
        >
          <article>
            <header class="mb-2 flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
              <h2 class="entry-title">{project.name}</h2>
              <span class="text-sm text-text-secondary">{project.category}</span>
            </header>
            <p class="entry-description">{project.description}</p>
            <footer class="entry-meta">
              <span>{project.url ? "Website" : "GitHub"}</span>
              <span>/</span>
              <span>{new URL(project.url ?? project.github).hostname}</span>
            </footer>
          </article>
        </a>
      ))
    }
  </section>
</BaseLayout>
