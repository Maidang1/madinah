---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  variant?: 'list' | 'post';
}

const { title = "Madinah's Blog", description = "A modern blog built with Astro", variant = 'post' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="h-full scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={Astro.url.href} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://assets.felixwliu.cn/fonts/jinkai/jinkai.css" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="Madinah's Blog" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Theme Script (must run before body renders to prevent flash) -->
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme');
        const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        const theme = savedTheme || systemTheme;

        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <script is:inline>
      const markMathJaxParents = () => {
        document.querySelectorAll('mjx-container').forEach((container) => {
          container.parentElement?.classList.add('has-jax');
        });
      };

      window.MathJax = {
        tex: {
          inlineMath: [['$', '$'], ['\\(', '\\)']],
          displayMath: [['$$', '$$'], ['\\[', '\\]']],
          processEscapes: true,
          processEnvironments: true
        },
        options: {
          skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre']
        },
        startup: {
          pageReady: () => window.MathJax.startup.defaultPageReady().then(markMathJaxParents)
        }
      };

      window.addEventListener('load', markMathJaxParents);
    </script>
    <script
      id="MathJax-script"
      async
      src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"
    ></script>

  </head>
  <body id="top" class:list={['site-shell font-sans antialiased', variant === 'list' ? 'site-list-surface' : 'site-post-surface']}>
    <div class="top-link-sentinel" aria-hidden="true"></div>
    <div class="flex min-h-[100dvh] flex-col">
      <main id="main-content" class="site-main flex-1">
        <slot />
      </main>

      <footer class="site-footer">
        <span>&copy; {new Date().getFullYear()} Madinah</span>
        <span>Built with Astro</span>
      </footer>

      <a class="top-link" href="#top" aria-label="Go to top" title="Go to top">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 6" fill="currentColor" aria-hidden="true">
          <path d="M12 6H0l6-6z" />
        </svg>
      </a>
    </div>
    <script is:inline>
      const topLink = document.querySelector('.top-link');
      const sentinel = document.querySelector('.top-link-sentinel');

      if (topLink && sentinel && 'IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          ([entry]) => topLink.classList.toggle('is-visible', !entry.isIntersecting),
          { rootMargin: '-400px 0px 0px 0px' }
        );

        observer.observe(sentinel);
      }
    </script>
  </body>
</html>
