---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle';

interface Props {
  title?: string;
  description?: string;
  variant?: 'list' | 'post';
}

const { title = "Madinah's Blog", description = "A modern blog built with Astro", variant = 'post' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN" class="h-full scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={Astro.url.href} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="Madinah's Blog" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Theme Script (must run before body renders to prevent flash) -->
    <script is:inline>
      // Immediately set theme before page renders
      (function() {
        const savedTheme = localStorage.getItem('theme');
        const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        const theme = savedTheme || systemTheme;

        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

  </head>
  <body class:list={['site-shell font-sans antialiased', variant === 'list' ? 'site-list-surface' : 'site-post-surface']}>
    <div class="flex min-h-[100dvh] flex-col">
      <header class="site-header">
        <div class="site-nav">
          <div class="flex items-center gap-3">
            <a href="/" class="site-brand">Madinah</a>
            <ThemeToggle client:idle />
          </div>

          <nav aria-label="Primary navigation">
            <ul class="site-menu">
              <li>
                <a href="/projects" aria-current={currentPath === "/projects" ? "page" : undefined}>
                  Projects
                </a>
              </li>
              <li>
                <a href="/blog" aria-current={currentPath.startsWith("/blog") ? "page" : undefined}>
                  Blog
                </a>
              </li>
            </ul>
          </nav>
        </div>
      </header>

      <main id="main-content" class="site-main flex-1">
        <slot />
      </main>

      <footer class="site-footer flex flex-wrap items-center justify-between gap-x-4 gap-y-1">
        <span>&copy; {new Date().getFullYear()} Madinah</span>
        <span>Built with Astro</span>
      </footer>
    </div>
  </body>
</html>
