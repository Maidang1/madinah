---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Madinah's Blog", description = "A modern blog built with Astro" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN" class="h-full scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={Astro.url.href} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="Madinah's Blog" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Theme Script (must run before body renders to prevent flash) -->
    <script is:inline>
      // Immediately set theme before page renders
      (function() {
        const savedTheme = localStorage.getItem('theme');
        const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        const theme = savedTheme || systemTheme;

        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-surface-gray-50 text-text-primary min-h-[100dvh] antialiased font-sans selection:bg-text-primary selection:text-surface-gray-50 dark:selection:bg-text-primary dark:selection:text-charcoal">
    <!-- Grain texture overlay -->
    <div class="pointer-events-none fixed inset-0 z-[100] opacity-[0.015] dark:opacity-[0.03]">
      <svg class="h-full w-full">
        <filter id="noise">
          <feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="4" stitchTiles="stitch" />
        </filter>
        <rect width="100%" height="100%" filter="url(#noise)" />
      </svg>
    </div>

    <div class="flex min-h-[100dvh] flex-col">
      <!-- Header -->
      <header class="bg-surface-gray-50/80 sticky top-0 z-50 w-full backdrop-blur-xl transition-all duration-200 border-b border-border-default/30">
        <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6 lg:px-8">
          <div class="flex items-center gap-8">
            <a
              href="/"
              class="group relative text-text-primary font-sans text-lg font-semibold tracking-tight transition-all duration-200 hover:opacity-70"
            >
              <span class="relative">
                Madinah
                <span class="absolute -bottom-0.5 left-0 h-px w-0 bg-text-primary transition-all duration-300 group-hover:w-full"></span>
              </span>
            </a>

            <ThemeToggle client:idle />

            <nav class="hidden items-center gap-1 sm:flex">
              <a
                href="/projects"
                class:list={[
                  "relative px-3 py-1.5 text-sm transition-colors duration-200 rounded-md",
                  currentPath === "/projects" ? "text-text-primary font-medium bg-surface-gray-100/70" : "text-text-secondary hover:text-text-primary hover:bg-surface-gray-100/50"
                ]}
              >
                Projects
              </a>
              <a
                href="/blog"
                class:list={[
                  "relative px-3 py-1.5 text-sm transition-colors duration-200 rounded-md",
                  currentPath.startsWith("/blog") ? "text-text-primary font-medium bg-surface-gray-100/70" : "text-text-secondary hover:text-text-primary hover:bg-surface-gray-100/50"
                ]}
              >
                Blog
              </a>
            </nav>
          </div>

          <!-- Mobile menu button -->
          <button
            class="flex h-9 w-9 items-center justify-center rounded-lg text-text-secondary hover:bg-surface-gray-100 hover:text-text-primary transition-colors sm:hidden"
            aria-label="Menu"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>
        </div>
      </header>

      <!-- Main Content -->
      <main
        id="main-content"
        class="mx-auto w-full max-w-6xl flex-1 px-6 py-12 sm:px-8 sm:py-16 lg:px-8 lg:py-20"
      >
        <slot />
      </main>

      <!-- Footer -->
      <footer class="border-t border-border-default/30">
        <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6 lg:px-8">
          <p class="text-sm text-text-muted">
            Built with Astro
          </p>
          <p class="text-sm text-text-muted">
            &copy; {new Date().getFullYear()} Madinah
          </p>
        </div>
      </footer>
    </div>
  </body>
</html>
